# Database
DATABASE__HOST=db
DATABASE__PORT=5432
DATABASE__USER=wagon
DATABASE__PASSWORD=wagon
DATABASE__NAME=wagon_monitor
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=20
DATABASE__ECHO=false

# JWT
JWT__SECRET=replace-me-with-32-plus-chars-of-random-data-please
JWT__ALGORITHM=HS256
JWT__EXPIRE_HOURS=24
JWT__RESET_EXPIRE_HOURS=2

# SMTP (optional)
SMTP__HOST=
SMTP__PORT=587
SMTP__USER=
SMTP__PASSWORD=
SMTP__USE_TLS=false
SMTP__START_TLS=true
SMTP__TIMEOUT=30
SMTP__FROM_ADDR=

# CORS — comma-separated origins (no wildcards)
CORS_ORIGINS=http://localhost,http://localhost:5173

# App
PUBLIC_URL=http://localhost
APP_TIMEZONE=Asia/Almaty
LOG_LEVEL=INFO

IS_TEST=false
